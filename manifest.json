{
  "manifest_version": 3,
  "name": "中超赛程",
  "version": "1.0.0",
  "description": "查看中超联赛赛程、战绩与积分榜",
  "action": {
    "default_popup": "popup.html",
    "default_title": "中超赛程",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["https://site.api.espn.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
